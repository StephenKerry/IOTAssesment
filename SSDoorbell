
#!/usr/bin/env python3
import time, json, sys, BlynkLib
import paho.mqtt.client as mqtt
from picamera2 import Picamera2
from upload_cloudinary import upload_image 

BLYNK_AUTH = "tWW99U8X0wmq84OLPbmp7vF8KRT3Gzmm"
MQTT_TOPIC = "/stephenpi/event/doorbell"
LOCAL_IMAGE = "last_visitor.jpg"
keep_running = True

blynk = BlynkLib.Blynk(BLYNK_AUTH, server='blynk.cloud')
client = mqtt.Client()
client.connect("broker.hivemq.com", 1883, 60)
client.loop_start()

picam2 = Picamera2()
picam2.configure(picam2.create_still_configuration())
picam2.start()

@blynk.VIRTUAL_WRITE(1)
def my_write_handler(value):
    global keep_running
    if int(value[0]) == 1:
        picam2.capture_file(LOCAL_IMAGE)
        url = upload_image(LOCAL_IMAGE)
        client.publish(MQTT_TOPIC, json.dumps({"image": url, "ts": int(time.time())}))
        blynk.log_event("doorbell_pressed", f"Photo: {url}")
        keep_running = False

print("Ring Doorbell!")

try:
    while keep_running:
        blynk.run()
        time.sleep(0.1)
    time.sleep(1) 
finally:
    picam2.stop()
    client.disconnect()
    sys.exit(0)
